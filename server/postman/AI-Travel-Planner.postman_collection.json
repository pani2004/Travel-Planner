    {
      "name": "Trips",
      "item": [
        {
          "name": "Generate Trip",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination\": \"Tokyo\",\n  \"numberOfDays\": 4,\n  \"budgetType\": \"Medium\",\n  \"interests\": [\"Food\", \"Culture\", \"Shopping\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/trips/generate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "trips",
                "generate"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Generate trip success\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "if (data.trip && data.trip._id) {",
                  "  pm.collectionVariables.set(\"tripId\", data.trip._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get My Trips",
          "request": {
            "method": "GET",
